# ---------------------------------------------------------------------------
# E2E test environment — LOCAL Supabase stack only, never production.
#
# Setup (one-time):
#   1. supabase start                  # boots the local stack + applies
#                                      # supabase/migrations/*
#   2. cp .env.e2e.example .env.e2e
#   3. supabase status                 # copy the anon + service_role keys
#                                      # into the two key vars below
#   4. node scripts/seed-e2e.mjs       # creates the test user (idempotent)
#   5. npx playwright test             # full suite, including auth/create
#
# When .env.e2e exists, playwright.config.ts runs its own dev server on
# port 3100 with these values — your :3000 server stays on .env.local.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon key from `supabase status`>
SUPABASE_SECRET_KEY=<service_role key from `supabase status`>

# Pricing specs need the paid layer visible; no Stripe keys required to
# render the pricing page locally.
NEXT_PUBLIC_BILLING_ENABLED=true

# Seeded test user (scripts/seed-e2e.mjs creates it with these values).
SUPABASE_E2E_USER_EMAIL=e2e@pipglyph.test
SUPABASE_E2E_USER_PASSWORD=pipglyph-e2e-password-1
