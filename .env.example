# Supabase
# Find these in your Supabase project under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — DO NOT expose to the browser.
# Only set this on the server when an operation truly requires it (e.g.
# admin-only background jobs). RLS-aware features should use the anon key.
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant (Phase 8)
# Anthropic API key for the in-creator AI helper. Without this the panel
# renders disabled buttons + an "AI not configured" note; the rest of the
# app still works.
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=

# Optional override of the model the AI assistant uses.
# Defaults to claude-haiku-4-5 — small, fast, good enough for card text.
# Switch to claude-sonnet-4-5 for higher-quality balance notes / concepts.
AI_CARD_MODEL=

# OpenAI — powers the "Generate random card" button (Phase v2 Phase 4).
# GPT-4o drafts the card text, DALL-E 3 generates the art.
# Without OPENAI_API_KEY the random-card button stays disabled with a
# "not configured" toast; the rest of the app still works.
# Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Optional model overrides. Defaults: gpt-4o for text, dall-e-3 for images.
OPENAI_RANDOM_CARD_MODEL=
OPENAI_IMAGE_MODEL=

# Scryfall — we identify ourselves in the User-Agent so Scryfall can rate-
# limit us correctly. Optional; defaults to "CardForge/1.0 (+<site>)".
SCRYFALL_USER_AGENT=
