# Supabase
# Find these in your Supabase project under Project Settings → API Keys.
# Uses the new key format: sb_publishable_... (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — DO NOT expose to the browser.
# Only set this on the server when an operation truly requires it (e.g.
# admin-only background jobs). RLS-aware features should use the
# publishable key.
SUPABASE_SECRET_KEY=

# AI assistant (Phase 8)
# Anthropic API key for the in-creator AI helper. Without this the panel
# renders disabled buttons + an "AI not configured" note; the rest of the
# app still works.
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=

# Optional override of the model the AI assistant uses.
# Defaults to claude-haiku-4-5 — small, fast, good enough for card text.
# Switch to claude-sonnet-4-5 for higher-quality balance notes / concepts.
AI_CARD_MODEL=

# OpenAI — powers the "Generate random card" button (Phase v2 Phase 4).
# GPT-4o drafts the card text, DALL-E 3 generates the art.
# Without OPENAI_API_KEY the random-card button stays disabled with a
# "not configured" toast; the rest of the app still works.
# Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Optional model overrides. Defaults: gpt-4o for text, gpt-image-1 for
# images. (dall-e-3 is being retired by OpenAI — many accounts get
# `The model 'dall-e-3' does not exist.` already. Set this to dall-e-3
# only if your account still has access.)
OPENAI_RANDOM_CARD_MODEL=
OPENAI_IMAGE_MODEL=

# Card-design engine (lib/ai/card-design.ts) ---------------------------------
# Powers card/set/deck generation text. Provider preference order:
#   1. Vercel AI Gateway (AI_GATEWAY_API_KEY set) — one key, provider
#      fallbacks, and image models we have no direct key for (FLUX etc.).
#      Create a key under the Vercel project → AI Gateway.
#   2. Direct Anthropic (ANTHROPIC_API_KEY above).
#   3. Direct OpenAI (OPENAI_API_KEY above) — legacy fallback.
AI_GATEWAY_API_KEY=

# Optional model overrides for the design engine. Accept either a gateway
# string ("anthropic/claude-sonnet-4-5") or a bare id ("claude-sonnet-4-5",
# "gpt-4o"). Defaults: claude-sonnet-4-5 designs, claude-haiku-4-5 judges.
AI_DESIGN_MODEL=
AI_JUDGE_MODEL=

# Image-to-image restyle for "AI remix" (lib/ai/image-gen.ts). With the
# gateway configured this multimodal model re-renders the original art in
# the requested style (default google/gemini-2.5-flash-image); without it
# the flow falls back to OpenAI images.edit on OPENAI_IMAGE_MODEL.
AI_IMAGE_REMIX_MODEL=

# Scryfall — we identify ourselves in the User-Agent so Scryfall can rate-
# limit us correctly. Optional; defaults to "PipGlyph/1.0 (+<site>)".
SCRYFALL_USER_AGENT=

# Site URL — absolute base used for Stripe success/cancel redirects, OG images,
# sitemap, etc. Set this in production (e.g. https://www.pipglyph.com). Falls back
# to Vercel's deploy URL, then http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 — set the GA4 measurement ID (G-XXXXXXXXXX) to enable
# analytics. Unset = no GA script is loaded at all (local dev, previews, e2e).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Billing master switch. Leave unset/false to keep the entire paid layer HIDDEN
# (no pricing page, no upgrade CTAs, no credit limits, no watermark) while
# retaining all the infrastructure. Set to "true" — with Stripe configured below
# — to go live. NEXT_PUBLIC_ so both server and client read it.
NEXT_PUBLIC_BILLING_ENABLED=

# Stripe (premium subscriptions + credit packs) ------------------------------
# Get keys at https://dashboard.stripe.com/apikeys. Use a RESTRICTED key in
# production. Without STRIPE_SECRET_KEY the billing UI shows "not available"
# and the rest of the app works normally.
STRIPE_SECRET_KEY=

# Webhook signing secret from `stripe listen` (dev) or the Dashboard endpoint
# (prod). The webhook route verifies every event against this.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create Products → Prices in the Dashboard). Each paid tier
# has a monthly + an annual recurring price ("2 months free"); packs are
# one-time. These map to the keys in lib/billing/plans.ts.
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PACK_SMALL=
STRIPE_PRICE_PACK_LARGE=

# Cron secret — Vercel sends this as `Authorization: Bearer <CRON_SECRET>` to
# scheduled routes (the monthly credit refill at /api/cron/refill-credits).
# Generate a long random string; set it in the Vercel project env.
CRON_SECRET=

# Moderation alerts (optional) ------------------------------------------------
# When a user files a content report, admins are pinged via any channel that's
# configured. All are best-effort — a delivery failure never fails the report.
#
# Slack: create an Incoming Webhook (https://api.slack.com/messaging/webhooks)
# and paste the URL here.
SLACK_WEBHOOK_URL=
#
# Email via Resend (https://resend.com). RESEND_API_KEY + ADMIN_ALERT_EMAIL are
# both required to enable email; ADMIN_ALERT_FROM must be a verified Resend
# sender/domain (defaults to Resend's onboarding sender, which only delivers to
# the account owner in test mode).
RESEND_API_KEY=
ADMIN_ALERT_EMAIL=
ADMIN_ALERT_FROM=

# Image content scan (NSFW auto-scan on art upload + AI generation) reuses
# OPENAI_API_KEY above via the free omni-moderation model. No extra key needed;
# if OPENAI_API_KEY is unset the scan is skipped (fails open).

# Environments (docs/ENVIRONMENTS.md) -----------------------------------------
# With Supabase branching enabled, migrations apply automatically (preview
# branch per PR; production on merge). These refs feed the MANUAL FALLBACK
# scripts only:
#   npm run db:push:prod     — out-of-band prod push (asks for confirmation)
#   npm run db:push:staging  — only if you create a persistent branch (a
#                              branch has its own project ref)
# The ref is the subdomain of the project's supabase.co URL. Refs aren't
# secrets, but they live here (not in the repo) so a fresh clone can't push
# migrations anywhere by accident.
SUPABASE_STAGING_REF=
SUPABASE_PROD_REF=
